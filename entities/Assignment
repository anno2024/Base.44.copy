{
  "name": "Assignment",
  "type": "object",
  "properties": {
    "course_id": {
      "type": "string",
      "description": "Reference to the course"
    },
    "title": {
      "type": "string",
      "description": "Assignment title"
    },
    "description": {
      "type": "string",
      "description": "Assignment description and instructions"
    },
    "questions": {
      "type": "array",
      "description": "List of questions",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "points": {
            "type": "number"
          },
          "rubric": {
            "type": "string"
          }
        }
      }
    },
    "due_date": {
      "type": "string",
      "format": "date-time"
    },
    "feedback_structure": {
      "type": "object",
      "description": "How feedback should be structured",
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include_suggestions": {
          "type": "boolean"
        },
        "include_strengths": {
          "type": "boolean"
        }
      }
    }
  },
  "required": [
    "course_id",
    "title"
  ]
}